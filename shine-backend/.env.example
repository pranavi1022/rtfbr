# ── SHINE Backend Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Flask
PORT=5000
FLASK_SECRET_KEY=shine_secret_key_2024

# MySQL (local development only — ignored when DATABASE_URL is set)
DB_HOST=localhost
DB_USER=root
DB_PASS=root123
DB_NAME=shine_db

# PostgreSQL (Render production — set this on Render dashboard)
# When DATABASE_URL is set, the app uses PostgreSQL instead of MySQL.
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Email OTP (Gmail SMTP — use an App Password, not your real password)
# Generate an App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=
EMAIL_PASS=
